---
// Proceso de trabajo
const steps = [
  { num: '01', title: 'Charlamos', desc: 'Me cuentas tu idea, objetivo y requisitos. Sin compromiso.' },
  { num: '02', title: 'Propuesta', desc: 'Te envío un presupuesto claro con plazo y entregables.' },
  { num: '03', title: 'Desarrollo', desc: 'Trabajamos together. Entrego avances semanales.' },
  { num: '04', title: 'Entrega', desc: 'Proyecto listo, documentado y con soporte post-entrega.' }
];
---

<section class="process section" id="proceso">
  <div class="container">
    <div class="process__header reveal">
      <p class="eyebrow">Proceso</p>
      <h2 class="display-lg">Así<span class="gradient-text">trabajamos.</span></h2>
    </div>

    <div class="process__steps">
      {steps.map((step, i) => (
        <div class={`process-step reveal reveal-delay-${i + 1}`}>
          <div class="process-step__num">{step.num}</div>
          <h3 class="process-step__title">{step.title}</h3>
          <p class="process-step__desc">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>