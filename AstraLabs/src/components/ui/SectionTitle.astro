---
interface Props {
    title: string;
    subtitle?: string;
    align?: "left" | "center";
}

const { title, subtitle, align = "center" } = Astro.props;
---

<div 
    class={`mb-8 sm:mb-12 md:mb-16 animate-section-title ${align === "center" ? "text-center" : ""}`}
    data-animate
>
    <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-display font-bold text-white relative inline-block">
        {title}
        <span class="block h-1 bg-clay-600 mt-2 sm:mt-4 w-12 sm:w-16 md:w-24"></span>
    </h2>
    {subtitle && (
        <p class="mt-4 sm:mt-6 text-stone-300 text-sm sm:text-base md:text-lg max-w-2xl mx-auto px-2">
            {subtitle}
        </p>
    )}
</div>

<style>
    .animate-section-title {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.7s ease-out, transform 0.7s ease-out;
    }

    .animate-section-title.visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>
