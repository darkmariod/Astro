---

---

<section class="projects section" id="proyectos">
  <div class="container">
    <div class="features__header reveal">
      <p class="eyebrow" data-i18n="projects.eyebrow">Proyectos</p>
      <h2 class="display-lg">
        <span data-i18n="projects.headline">Trabajos</span><span class="gradient-text" data-i18n="projects.titleAccent">recientes.</span>
      </h2>
    </div>

    <div class="bento">
      <!-- E-commerce  -->
      <a href="#contacto" class="card bento__card reveal">
        <div class="bento__card-inner">
          <div class="icon-glow" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="9" cy="21" r="1"/>
              <circle cx="20" cy="21" r="1"/>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
          </div>
          <div class="bento__card-text">
            <span class="bento__card-category">Tienda Online</span>
            <h3 class="bento__card-title">E-commerce Natufitneess</h3>
            <p class="bento__card-desc">
              Tienda online con pagos, inventario y panel administrativo lista para vender.
            </p>
            <div class="bento__chips">
              <span class="bento__agent-chip">Laravel</span>
            </div>
          </div>
        </div>
      </a>

      <!-- Dashboard SaaS -->
      <a href="#contacto" class="card bento__card reveal reveal-delay-1">
        <div class="bento__card-inner">
          <div class="icon-glow" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="3" width="18" height="14" rx="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </div>
          <div class="bento__card-text">
            <span class="bento__card-category">Sistema</span>
            <h3 class="bento__card-title">Dashboard SaaS</h3>
            <p class="bento__card-desc">
              Sistema de control con inventario y analítica en tiempo real para gestión de inventario de arquitectos.
            </p>
            <div class="bento__chips">
              <span class="bento__agent-chip">Laravel</span>
            </div>
          </div>
        </div>
      </a>

      <!-- Chatbot WhatsApp -->
      <a href="#contacto" class="card bento__card reveal reveal-delay-2">
        <div class="bento__card-inner">
          <div class="icon-glow" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="11" cy="11" r="9"/>
              <circle cx="11" cy="11" r="3"/>
              <path d="M11 5v2"/>
            </svg>
          </div>
          <div class="bento__card-text">
            <span class="bento__card-category">Chatbot</span>
            <h3 class="bento__card-title">Chatbot WhatsApp</h3>
            <p class="bento__card-desc">
              Automatización de atención al cliente conectada a WhatsApp para responder 24/7, para un negocio de comida.
            </p>
            <div class="bento__chips">
              <span class="bento__agent-chip">WhatsApp API</span>
              <span class="bento__agent-chip">Nuxt.js</span>
            </div>
          </div>
        </div>
      </a>

      <!-- Web Turismo -->
      <a href="#contacto" class="card bento__card reveal reveal-delay-3">
        <div class="bento__card-inner">
          <div class="icon-glow" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M2 11h18M11 2v18"/>
              <circle cx="11" cy="11" r="9"/>
            </svg>
          </div>
          <div class="bento__card-text">
            <span class="bento__card-category">Página Web</span>
            <h3 class="bento__card-title">Web Agencia de Turismo</h3>
            <p class="bento__card-desc">
              Página web para agencia de turismo en Ecuador con animaciones modernas y enfoque en captar clientes.
            </p>
            <div class="bento__chips">
              <span class="bento__agent-chip">React</span>
              <span class="bento__agent-chip">Framer Motion</span>
              <span class="bento__agent-chip">Sanity CMS</span>
            </div>
          </div>
        </div>
      </a>

    </div>
  </div>
</section>
