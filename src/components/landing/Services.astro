---
// Features — Bento grid with 6 key features
---

<section class="features section" id="servicios">
  <div class="container">
    <div class="features__header reveal">
      <p class="eyebrow" data-i18n="services.eyebrow">Servicios</p>
      <h2 class="display-lg features__headline">
        <span data-i18n="services.headline">Automatiza tu negocio y consiga más clientes</span>
      </h2>
    </div>

    <div class="bento">
      <div class="card bento__card reveal">
        <div class="bento__card-inner">
          <div class="icon-glow" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
          </div>
          <div class="bento__card-text">
            <h3 class="bento__card-title" data-i18n="services.items.paginasWeb.title">Páginas Web</h3>
            <p class="bento__card-desc" data-i18n="services.items.paginasWeb.desc">Landing pages y sitios web diseñados para convertir visitantes en clientes.</p>
            <div class="bento__chips">
              <span class="bento__agent-chip">Astro</span>
              <span class="bento__agent-chip">React</span>
              <span class="bento__agent-chip">SEO</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Tiendas Online -->
      <div class="card bento__card reveal reveal-delay-1">
        <div class="bento__card-inner">
          <div class="icon-glow" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="9" cy="21" r="1"/>
              <circle cx="20" cy="21" r="1"/>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
          </div>
          <div class="bento__card-text">
            <h3 class="bento__card-title" data-i18n="services.items.tiendasOnline.title">Tiendas Online</h3>
            <p class="bento__card-desc" data-i18n="services.items.tiendasOnline.desc">
              E-commerce con carrito, pagos seguros y gestión de inventario integrada.
            </p>
            <div class="bento__chips">
              <span class="bento__agent-chip">Shopify</span>
              <span class="bento__agent-chip">WooCommerce</span>
              <span class="bento__agent-chip">Pagos</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Paneles Admin -->
      <div class="card bento__card reveal reveal-delay-2">
        <div class="bento__card-inner">
          <div class="icon-glow" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="3" width="18" height="14" rx="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </div>
          <div class="bento__card-text">
            <h3 class="bento__card-title" data-i18n="services.items.panelesAdmin.title">Paneles Admin</h3>
            <p class="bento__card-desc" data-i18n="services.items.panelesAdmin.desc">
              Dashboards a medida para gestionar clientes, ventas, inventario y más.
            </p>
            <div class="bento__chips">
              <span class="bento__agent-chip">Laravel</span>
              <span class="bento__agent-chip">FastAPI</span>
              <span class="bento__agent-chip">React</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Chatbots -->
      <div class="card bento__card reveal reveal-delay-1">
        <div class="bento__card-inner">
          <div class="icon-glow" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="11" cy="11" r="9"/>
              <circle cx="11" cy="11" r="3"/>
              <path d="M11 5v2"/>
            </svg>
          </div>
          <div class="bento__card-text">
            <h3 class="bento__card-title" data-i18n="services.items.chatbots.title">Chatbots</h3>
            <p class="bento__card-desc" data-i18n="services.items.chatbots.desc">
              Asistentes IA para WhatsApp y web que responden 24/7 y cierran ventas.
            </p>
            <div class="bento__chips">
              <span class="bento__agent-chip">WhatsApp API</span>
              <span class="bento__agent-chip">GPT</span>
              <span class="bento__agent-chip">Automation</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Apps Móviles -->
      <div class="card bento__card reveal reveal-delay-2">
        <div class="bento__card-inner">
          <div class="icon-glow" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="5" y="2" width="12" height="20" rx="2" ry="2"/>
              <line x1="12" y1="18" x2="12.01" y2="18"/>
            </svg>
          </div>
          <div class="bento__card-text">
            <h3 class="bento__card-title" data-i18n="services.items.appsMoviles.title">Apps Móviles</h3>
            <p class="bento__card-desc" data-i18n="services.items.appsMoviles.desc">
              Aplicaciones nativas para iOS y Android con la mejor experiencia de usuario.
            </p>
            <div class="bento__chips">
              <span class="bento__agent-chip">Flutter</span>
              <span class="bento__agent-chip">React Native</span>
              <span class="bento__agent-chip">Push</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Automatizaciones -->
      <div class="card bento__card reveal reveal-delay-3">
        <div class="bento__card-inner">
          <div class="icon-glow" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5"/>
            </svg>
          </div>
          <div class="bento__card-text">
            <h3 class="bento__card-title" data-i18n="services.items.automatizaciones.title">Automatizaciones</h3>
            <p class="bento__card-desc" data-i18n="services.items.automatizaciones.desc">
              Workflows que eliminan tareas repetitivas: encuestas, seguimientos, facturación.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
