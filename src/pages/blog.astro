---
import Layout from "@/layouts/Layout.astro";
import bg from "@/assets/bg_home.jpg";
---

<Layout title="Blog" subtitle="Reflexiones" bgImage={bg.src}>
    
    <!-- Intro -->
    <section class="text-center px-5 py-10 sm:py-12" data-animate>
        <p class="text-stone-300 text-lg sm:text-xl md:text-2xl max-w-3xl mx-auto leading-relaxed">
            Reflexiones y experiencias sobre activación del patrimonio vivo, mediación cultural y trabajo ético con comunidades.
        </p>
    </section>

    <!-- Posts -->
    <section class="mb-10 sm:mb-14 px-5">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 sm:gap-6 max-w-5xl mx-auto">
            <!-- Post 1 -->
            <article class="bg-soil-raised rounded-xl overflow-hidden" data-animate>
                <a href="/blog/escucha-territorial/" class="block">
                    <div class="relative h-48 sm:h-56 overflow-hidden">
                        <img 
                            src="https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=800&q=80"
                            alt="Escucha territorial"
                            class="w-full h-full object-cover"
                        />
                        <span class="absolute top-3 left-3 bg-clay-600 text-white text-xs font-bold uppercase px-3 py-1.5 rounded-full tracking-wider">
                            Metodología
                        </span>
                    </div>
                    <div class="p-5 sm:p-6">
                        <p class="text-stone-400 text-sm mb-3">20 Marzo 2026 • 10 min</p>
                        <h2 class="text-xl sm:text-2xl font-display font-bold text-white mb-3 line-clamp-2 leading-tight">
                            La importancia de la escucha territorial en proyectos culturales
                        </h2>
                        <p class="text-stone-300 text-base sm:text-lg line-clamp-3 leading-relaxed">
                            Antes de cualquier proceso de documentación, es fundamental establecer vínculos genuinos con el territorio y sus comunidades.
                        </p>
                        <span class="inline-block mt-4 text-clay-400 text-sm font-semibold">
                            Leer más →
                        </span>
                    </div>
                </a>
            </article>

            <!-- Post 2 -->
            <article class="bg-soil-raised rounded-xl overflow-hidden" data-animate>
                <a href="/blog/documentacion-etica/" class="block">
                    <div class="relative h-48 sm:h-56 overflow-hidden">
                        <img 
                            src="https://images.unsplash.com/photo-1460661419201-fd4cecdf8a8b?w=800&q=80"
                            alt="Documentación ética"
                            class="w-full h-full object-cover"
                        />
                        <span class="absolute top-3 left-3 bg-clay-600 text-white text-xs font-bold uppercase px-3 py-1.5 rounded-full tracking-wider">
                            Reflexión
                        </span>
                    </div>
                    <div class="p-5 sm:p-6">
                        <p class="text-stone-400 text-sm mb-3">15 Marzo 2026 • 8 min</p>
                        <h2 class="text-xl sm:text-2xl font-display font-bold text-white mb-3 line-clamp-2 leading-tight">
                            Documentación ética: más allá de la fotografía
                        </h2>
                        <p class="text-stone-300 text-base sm:text-lg line-clamp-3 leading-relaxed">
                            Cuando documentamos saberes ancestrales, estamos construyendo archivos que deben respetar la soberanía de las comunidades.
                        </p>
                        <span class="inline-block mt-4 text-clay-400 text-sm font-semibold">
                            Leer más →
                        </span>
                    </div>
                </a>
            </article>
        </div>
    </section>

    <!-- Newsletter -->
    <section class="py-10 sm:py-14 bg-clay-600 rounded-xl mx-5" data-animate>
        <div class="max-w-xl mx-auto px-5 text-center">
            <h2 class="text-2xl sm:text-3xl font-display font-bold text-white mb-3">
                Boletín Ancestral Lab
            </h2>
            <p class="text-white/80 mb-6 text-base sm:text-lg">
                Recibe reflexiones y herramientas sobre patrimonio vivo.
            </p>
            <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
                <input 
                    type="email" 
                    placeholder="Tu email"
                    class="flex-1 px-4 py-3.5 bg-white/10 border border-white/20 rounded-full text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-white/50 text-base"
                />
                <button 
                    type="submit"
                    class="px-6 py-3.5 bg-soil-void hover:bg-soil-deep text-white font-semibold uppercase rounded-full transition-all hover:scale-105 text-sm tracking-wider"
                >
                    Suscribirse
                </button>
            </form>
        </div>
    </section>
</Layout>

<script>
    const animateOnScroll = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('[data-animate]').forEach((el) => {
        animateOnScroll.observe(el);
    });
</script>

<style>
    [data-animate] {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.5s ease-out, transform 0.5s ease-out;
    }
    [data-animate].visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>
