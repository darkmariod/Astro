---
import Layout from "@/layouts/Layout.astro";
import bg from "@/assets/bg_home.jpg";
---

<Layout title="Contacto" subtitle="Contacto" bgImage={bg.src}>
    
    <section class="py-10 sm:py-14 md:py-16 px-5">
        <div class="grid md:grid-cols-2 gap-10 sm:gap-12 lg:gap-16">
            
            <!-- Formulario -->
            <div data-animate>
                <h2 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-white mb-5">
                    Iniciemos un <span class="text-clay-400">diálogo</span>
                </h2>
                <p class="text-stone-300 mb-8 text-lg sm:text-xl leading-relaxed">
                    ¿Tienes un proyecto cultural en mente? ¿Quieres explorar posibilidades de co-creación desde el territorio? Escríbenos y respondemos desde la escucha.
                </p>
                
                <form class="space-y-5 sm:space-y-6">
                    <div class="grid sm:grid-cols-2 gap-5">
                        <div>
                            <label class="block text-stone-300 text-base font-semibold mb-2" for="name">
                                Nombre
                            </label>
                            <input 
                                type="text" 
                                id="name" 
                                name="name"
                                class="w-full px-4 py-3.5 bg-soil-raised border border-soil-raised focus:border-clay-600 rounded-xl text-white placeholder-stone-500 focus:outline-none focus:ring-2 focus:ring-clay-600 transition-colors text-base"
                                placeholder="Tu nombre"
                                required
                            />
                        </div>
                        <div>
                            <label class="block text-stone-300 text-base font-semibold mb-2" for="email">
                                Email
                            </label>
                            <input 
                                type="email" 
                                id="email" 
                                name="email"
                                class="w-full px-4 py-3.5 bg-soil-raised border border-soil-raised focus:border-clay-600 rounded-xl text-white placeholder-stone-500 focus:outline-none focus:ring-2 focus:ring-clay-600 transition-colors text-base"
                                placeholder="tu@email.com"
                                required
                            />
                        </div>
                    </div>
                    
                    <div>
                        <label class="block text-stone-300 text-base font-semibold mb-2" for="organization">
                            Organización o Comunidad (opcional)
                        </label>
                        <input 
                            type="text" 
                            id="organization" 
                            name="organization"
                            class="w-full px-4 py-3.5 bg-soil-raised border border-soil-raised focus:border-clay-600 rounded-xl text-white placeholder-stone-500 focus:outline-none focus:ring-2 focus:ring-clay-600 transition-colors text-base"
                            placeholder="Nombre de tu organización"
                        />
                    </div>
                    
                    <div>
                        <label class="block text-stone-300 text-base font-semibold mb-2" for="phone">
                            Teléfono (opcional)
                        </label>
                        <input 
                            type="tel" 
                            id="phone" 
                            name="phone"
                            class="w-full px-4 py-3.5 bg-soil-raised border border-soil-raised focus:border-clay-600 rounded-xl text-white placeholder-stone-500 focus:outline-none focus:ring-2 focus:ring-clay-600 transition-colors text-base"
                            placeholder="0991234567"
                        />
                    </div>
                    
                    <div>
                        <label class="block text-stone-300 text-base font-semibold mb-2" for="subject">
                            Tipo de consulta
                        </label>
                        <select 
                            id="subject" 
                            name="subject"
                            class="w-full px-4 py-3.5 bg-soil-raised border border-soil-raised focus:border-clay-600 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-clay-600 transition-colors text-base"
                            required
                        >
                            <option value="">Selecciona una opción</option>
                            <option value="laboratorio">Laboratorio Cultural</option>
                            <option value="taller">Taller o Mediación</option>
                            <option value="documentacion">Documentación Ética</option>
                            <option value="proyecto">Diseño de Proyecto</option>
                            <option value="colaboracion">Propuesta de Colaboración</option>
                            <option value="otro">Otro</option>
                        </select>
                    </div>
                    
                    <div>
                        <label class="block text-stone-300 text-base font-semibold mb-2" for="message">
                            Cuéntanos tu proyecto o consulta
                        </label>
                        <textarea 
                            id="message" 
                            name="message"
                            rows="5"
                            class="w-full px-4 py-3.5 bg-soil-raised border border-soil-raised focus:border-clay-600 rounded-xl text-white placeholder-stone-500 focus:outline-none focus:ring-2 focus:ring-clay-600 transition-colors resize-none text-base"
                            placeholder="Describe tu proyecto o consulta..."
                            required
                        ></textarea>
                    </div>
                    
                    <button 
                        type="submit"
                        class="w-full bg-clay-600 hover:bg-clay-700 text-white font-semibold uppercase text-base px-8 py-4 rounded-full transition-all hover:scale-[1.02] tracking-wider"
                    >
                        Enviar Mensaje
                    </button>
                </form>
            </div>
            
            <!-- Info de contacto -->
            <div data-animate class="mt-10 md:mt-0">
                <h2 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-white mb-5">
                    Información de <span class="text-clay-400">contacto</span>
                </h2>
                
                <p class="text-stone-300 mb-8 text-lg sm:text-xl leading-relaxed">
                    Respondemos a cada mensaje con la atención que merece. El tiempo es un valor en nuestros procesos.
                </p>
                
                <div class="space-y-5 sm:space-y-6 mb-10">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 bg-clay-600/20 rounded-xl flex items-center justify-center shrink-0">
                            <span class="text-xl">📧</span>
                        </div>
                        <div>
                            <h3 class="text-white font-semibold mb-1 text-lg">Email</h3>
                            <a href="mailto:contacto@ancestrallab.com" class="text-clay-400 hover:text-clay-300 transition-colors text-lg">
                                contacto@ancestrallab.com
                            </a>
                        </div>
                    </div>
                    
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 bg-clay-600/20 rounded-xl flex items-center justify-center shrink-0">
                            <span class="text-xl">👤</span>
                        </div>
                        <div>
                            <h3 class="text-white font-semibold mb-1 text-lg">Impulsor</h3>
                            <p class="text-stone-300 text-lg">Yaku Heredia</p>
                            <p class="text-stone-400 text-base">Mediador Cultural y Narrador Visual</p>
                        </div>
                    </div>
                    
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 bg-clay-600/20 rounded-xl flex items-center justify-center shrink-0">
                            <span class="text-xl">🌐</span>
                        </div>
                        <div>
                            <h3 class="text-white font-semibold mb-1 text-lg">Territorio</h3>
                            <p class="text-stone-300 text-lg">Ecuador</p>
                            <p class="text-stone-400 text-base">Trabajos en toda América Latina</p>
                        </div>
                    </div>
                </div>
                
                <!-- Redes sociales -->
                <div class="mb-8">
                    <h3 class="text-white font-semibold mb-4 text-lg">Síguenos</h3>
                    <div class="flex gap-3">
                        <a href="#" class="w-12 h-12 bg-soil-raised hover:bg-clay-600 rounded-xl flex items-center justify-center transition-colors" title="Instagram">
                            <span class="text-xl">📸</span>
                        </a>
                        <a href="#" class="w-12 h-12 bg-soil-raised hover:bg-clay-600 rounded-xl flex items-center justify-center transition-colors" title="YouTube">
                            <span class="text-xl">▶️</span>
                        </a>
                        <a href="#" class="w-12 h-12 bg-soil-raised hover:bg-clay-600 rounded-xl flex items-center justify-center transition-colors" title="Facebook">
                            <span class="text-xl">📘</span>
                        </a>
                    </div>
                </div>
                
                <!-- Lema -->
                <div class="bg-soil-raised p-6 sm:p-7 rounded-xl">
                    <p class="text-clay-400 font-display italic text-xl sm:text-2xl leading-relaxed">
                        "Nada se publica sin devolución.<br />Nada se crea sin escucha."
                    </p>
                </div>
            </div>
        </div>
    </section>
</Layout>

<script>
    const animateOnScroll = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('[data-animate]').forEach((el) => {
        animateOnScroll.observe(el);
    });

    const form = document.querySelector('form');
    form?.addEventListener('submit', (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);
        
        const message = encodeURIComponent(
            `Nuevo mensaje de contacto:\n\n` +
            `Nombre: ${data.name}\n` +
            `Email: ${data.email}\n` +
            `Organización: ${data.organization || 'No especificada'}\n` +
            `Tipo de consulta: ${data.subject}\n` +
            `Mensaje: ${data.message}`
        );
        
        window.location.href = `https://wa.me/593991234567?text=${message}`;
    });
</script>

<style>
    [data-animate] {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    [data-animate].visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>
