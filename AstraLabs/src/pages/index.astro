---
import Layout from "@/layouts/Layout.astro";
import bg from "@/assets/bg_home.jpg";
import Card from "@/components/ui/Card.astro";
import SectionTitle from "@/components/ui/SectionTitle.astro";

// Datos reales basados en el brief de Ancestral Lab
const servicios = [
    {
        title: "Laboratorios Culturales",
        description: "Espacios de creación y experimentación donde el patrimonio vivo se encuentra con propuestas contemporáneas.",
        image: "https://images.unsplash.com/photo-1531058020387-3be344556be6?w=800&q=80",
        category: "Servicio",
        link: "/servicios/laboratorios"
    },
    {
        title: "Mediación y Narrativa Visual",
        description: "Talleres para aprender a documentar y contar historias desde una mirada ética y comunitaria.",
        image: "https://images.unsplash.com/photo-1456324504439-367cee3b3c32?w=800&q=80",
        category: "Taller",
        link: "/servicios/talleres"
    },
    {
        title: "Documentación Ética",
        description: "Procesos de registro y archivo que respetan la soberanía de las comunidades sobre sus saberes.",
        image: "https://images.unsplash.com/photo-1460661419201-fd4cecdf8a8b?w=800&q=80",
        category: "Servicio",
        link: "/servicios/documentacion"
    }
];

const metodology = [
    {
        moment: "01",
        title: "Escucha Territorial",
        description: "Reconocimiento, diálogo y construcción de vínculos con las comunidades y el territorio."
    },
    {
        moment: "02",
        title: "Investigación Sensible",
        description: "Aprendizaje desde la experiencia, el cuerpo y la palabra."
    },
    {
        moment: "03",
        title: "Creación y Mediación",
        description: "Procesos visuales, escritos y laboratorios culturales."
    },
    {
        moment: "04",
        title: "Devolución y Circulación",
        description: "Socialización comunitaria y archivo consciente."
    }
];
---

<Layout title="Inicio" subtitle="Ancestral Lab" bgImage={bg.src}>
    
    <!-- Hero Section - Estilo ojodenomada con tipografía grande -->
    <section class="text-center px-4 py-16 sm:py-20 md:py-24" data-animate>
        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-display font-bold text-white mb-6 sm:mb-8 leading-[1.1] tracking-tight">
            Activación del<br />
            <span class="text-clay-400">Patrimonio Vivo</span>
        </h1>
        <p class="text-stone-300 text-lg sm:text-xl md:text-2xl max-w-3xl mx-auto mb-8 sm:mb-10 px-2 leading-relaxed">
            Plataforma cultural y metodológica dedicada a la activación del patrimonio vivo y los saberes ancestrales desde el territorio.
        </p>
        <a href="/nosotros/" class="inline-block bg-clay-600 hover:bg-clay-700 text-white font-semibold uppercase text-sm sm:text-base tracking-wider px-8 sm:px-10 py-4 sm:py-5 rounded-full transition-all hover:scale-105">
            Conoce Nuestra Metodología
        </a>
    </section>

    <!-- Propósito -->
    <section class="py-16 sm:py-20 md:py-24 border-t border-soil-raised">
        <div class="max-w-6xl mx-auto px-5">
            <SectionTitle 
                title="Nuestra Mirada"
                subtitle="La cultura es un cuerpo vivo en constante transformación, no algo estático para museos."
                align="center"
            />
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mt-10 sm:mt-14">
                <div class="bg-soil-raised p-6 sm:p-8 rounded-xl text-center" data-animate>
                    <div class="text-4xl sm:text-5xl mb-5">🌱</div>
                    <h3 class="text-xl sm:text-2xl font-display font-bold text-white mb-4">Patrimonio en la Práctica</h3>
                    <p class="text-stone-300 text-base sm:text-lg leading-relaxed">
                        Se conserva en lo cotidiano: oficios, palabra, imagen y relación con el territorio.
                    </p>
                </div>
                <div class="bg-soil-raised p-6 sm:p-8 rounded-xl text-center" data-animate>
                    <div class="text-4xl sm:text-5xl mb-5">🤝</div>
                    <h3 class="text-xl sm:text-2xl font-display font-bold text-white mb-4">Diálogo Contemporáneo</h3>
                    <p class="text-stone-300 text-base sm:text-lg leading-relaxed">
                        Trabajamos con saberes ancestrales sin folklorizarlos, reconociendo a las comunidades como sujetos activos.
                    </p>
                </div>
                <div class="bg-soil-raised p-6 sm:p-8 rounded-xl text-center md:col-span-1" data-animate>
                    <div class="text-4xl sm:text-5xl mb-5">🛡️</div>
                    <h3 class="text-xl sm:text-2xl font-display font-bold text-white mb-4">No Extractivismo</h3>
                    <p class="text-stone-300 text-base sm:text-lg leading-relaxed">
                        No somos un proyecto extractivo ni superficial. El conocimiento se comparte, no se extrae.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Metodología -->
    <section class="py-16 sm:py-20 md:py-24 bg-soil-mid">
        <div class="max-w-6xl mx-auto px-5">
            <SectionTitle 
                title="Metodología Ancestral Lab"
                subtitle="Cuatro momentos para activar el patrimonio vivo de manera ética y comunitaria."
            />
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mt-10 sm:mt-14">
                {metodology.map((step, index) => (
                    <div 
                        class="relative bg-soil-raised p-6 sm:p-8 rounded-xl border-l-4 border-clay-600 animate-method"
                        data-index={index}
                    >
                        <span class="text-5xl sm:text-6xl md:text-7xl font-display font-bold text-clay-600/20 absolute top-4 right-4 sm:top-6 sm:right-6">
                            {step.moment}
                        </span>
                        <h3 class="text-xl sm:text-2xl font-display font-bold text-white mb-4 relative z-10">
                            {step.title}
                        </h3>
                        <p class="text-stone-300 text-sm sm:text-base leading-relaxed relative z-10">
                            {step.description}
                        </p>
                    </div>
                ))}
            </div>
            
            <p class="text-center text-clay-400 mt-8 sm:mt-10 italic font-display text-base sm:text-lg px-4">
                "Nada se publica sin devolución. Nada se crea sin escucha."
            </p>
        </div>
    </section>

    <!-- Servicios -->
    <section class="py-16 sm:py-20 md:py-24">
        <div class="max-w-6xl mx-auto px-5">
            <SectionTitle 
                title="Nuestras Líneas de Trabajo"
                subtitle="Procesos de creación, mediación cultural, educación y comunicación ética."
            />
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6 mt-10 sm:mt-14">
                {servicios.map((item, index) => (
                    <Card 
                        title={item.title}
                        description={item.description}
                        image={item.image}
                        category={item.category}
                        link={item.link}
                        index={index}
                    />
                ))}
            </div>
        </div>
    </section>

    <!-- Quiénes trabajamos -->
    <section class="py-16 sm:py-20 md:py-24 bg-soil-mid">
        <div class="max-w-6xl mx-auto px-5">
            <SectionTitle 
                title="Con Quiénes Trabajamos"
                subtitle="Alianzas y procesos con comunidades, instituciones y proyectos que comparten nuestra mirada."
            />
            
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5 mt-10 sm:mt-14">
                <div class="bg-soil-raised p-5 sm:p-7 rounded-xl text-center" data-animate>
                    <div class="text-3xl sm:text-4xl mb-4">🏘️</div>
                    <h3 class="text-white font-semibold text-base sm:text-lg">Comunidades</h3>
                    <p class="text-stone-400 text-sm mt-2">Portadores de saber</p>
                </div>
                <div class="bg-soil-raised p-5 sm:p-7 rounded-xl text-center" data-animate>
                    <div class="text-3xl sm:text-4xl mb-4">🎓</div>
                    <h3 class="text-white font-semibold text-base sm:text-lg">Educación</h3>
                    <p class="text-stone-400 text-sm mt-2">Jóvenes y procesos</p>
                </div>
                <div class="bg-soil-raised p-5 sm:p-7 rounded-xl text-center" data-animate>
                    <div class="text-3xl sm:text-4xl mb-4">🏛️</div>
                    <h3 class="text-white font-semibold text-base sm:text-lg">Instituciones</h3>
                    <p class="text-stone-400 text-sm mt-2">Espacios culturales</p>
                </div>
                <div class="bg-soil-raised p-5 sm:p-7 rounded-xl text-center" data-animate>
                    <div class="text-3xl sm:text-4xl mb-4">🤝</div>
                    <h3 class="text-white font-semibold text-base sm:text-lg">Cooperación</h3>
                    <p class="text-stone-400 text-sm mt-2">Proyectos sostenibles</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-16 sm:py-20 md:py-24 bg-clay-600" data-animate>
        <div class="max-w-4xl mx-auto px-5 text-center">
            <h2 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-white mb-6">
                ¿Quieres activar patrimonio vivo en tu territorio?
            </h2>
            <p class="text-white/80 text-lg sm:text-xl mb-10 px-2 leading-relaxed">
                Contáctanos para explorar posibilidades de co-creación.
            </p>
            <a href="/contacto/" class="inline-block bg-soil-void hover:bg-soil-deep text-white font-semibold uppercase text-sm sm:text-base tracking-wider px-10 py-4 rounded-full transition-all hover:scale-105">
                Escríbenos
            </a>
        </div>
    </section>
</Layout>

<script>
    const animateOnScroll = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('[data-animate]').forEach((el) => {
        animateOnScroll.observe(el);
    });

    document.querySelectorAll('[data-animate-card]').forEach((el, index) => {
        (el as HTMLElement).style.transitionDelay = `${index * 100}ms`;
        animateOnScroll.observe(el);
    });

    document.querySelectorAll('.animate-method').forEach((el, index) => {
        (el as HTMLElement).style.transitionDelay = `${index * 150}ms`;
        animateOnScroll.observe(el);
    });
</script>

<style>
    [data-animate] {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    [data-animate].visible {
        opacity: 1;
        transform: translateY(0);
    }

    .animate-method {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.5s ease-out, transform 0.5s ease-out;
    }
    .animate-method.visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>
