---
import Layout from "@/layouts/Layout.astro";
import bg from "@/assets/bg_home.jpg";
import SectionTitle from "@/components/ui/SectionTitle.astro";

const values = [
    {
        title: "Living Heritage",
        icon: "🌱",
        description: "We don't museify culture. We preserve it in everyday practice."
    },
    {
        title: "Territory",
        icon: "🗺️",
        description: "The territory is a source of knowledge, not an extraction scenario."
    },
    {
        title: "Non-Extraction",
        icon: "🛡️",
        description: "We're not an extractive or superficial project. Knowledge is shared."
    },
    {
        title: "Co-creation",
        icon: "🤝",
        description: "Active listening and co-creation with communities as subjects."
    },
    {
        title: "Time",
        icon: "⏳",
        description: "Time is a value. Processes cannot be accelerated."
    },
    {
        title: "Ethical Education",
        icon: "🎓",
        description: "Cultural education is an ethical and political act, not a product."
    }
];

const principles = [
    "Living heritage, not museumified.",
    "Territory as a source of knowledge.",
    "No cultural extractivism.",
    "Co-creation and active listening.",
    "Time as a value.",
    "Cultural education as an ethical and political act."
];
---

< Layout title="About Us" subtitle="About Us" bgImage={bg.src}>
    
    <!-- Identidad -->
    <section class="py-10 sm:py-14 md:py-16">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-8 items-center">
            <div data-animate>
                <img 
                    src="https://images.unsplash.com/photo-1531058020387-3be344556be6?w=800&q=80" 
                    alt="Ancestral Lab"
                    class="rounded-xl w-full h-48 sm:h-56 md:h-72 object-cover"
                />
            </div>
            <div data-animate class="mt-5 sm:mt-0">
                <h1 class="text-2xl sm:text-3xl md:text-4xl font-display font-bold text-white mb-4">
                    Ancestral <span class="text-clay-400">Lab</span>
                </h1>
                <p class="text-stone-300 text-base sm:text-lg mb-3 leading-relaxed">
                    Ancestral Lab is a cultural and methodological platform dedicated to the <strong class="text-white">activation of living heritage</strong> and ancestral knowledge from the territory.
                </p>
                <p class="text-stone-300 text-base sm:text-lg mb-3 leading-relaxed">
                    <strong class="text-white">Focus:</strong> Processes of creation, cultural mediation, education, and ethical communication.
                </p>
                <p class="text-stone-300 text-base sm:text-lg">
                    It's not an extractive or superficial project. It's a <strong class="text-clay-400">living laboratory</strong> where memory is practiced.
                </p>
            </div>
        </div>
    </section>

    <!-- Principios -->
    <section class="py-10 sm:py-14 md:py-16 bg-soil-mid rounded-xl px-5 sm:px-6">
        <SectionTitle 
            title="Core Principles"
            subtitle="The pillars that guide every process."
        />
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 mt-8 sm:mt-10">
            {principles.map((principle) => (
                <div class="flex items-start gap-3 bg-soil-raised p-4 sm:p-5 rounded-xl">
                    <span class="w-2 h-2 bg-clay-600 rounded-full mt-2 shrink-0"></span>
                    <p class="text-stone-200 text-base sm:text-lg">{principle}</p>
                </div>
            ))}
        </div>
    </section>

    <!-- Visión y Misión -->
    <section class="py-10 sm:py-14 md:py-16">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5">
            <div class="bg-soil-raised p-5 sm:p-7 rounded-xl" data-animate>
                <h3 class="text-xl sm:text-2xl font-display font-bold text-clay-400 mb-3">Vision</h3>
                <p class="text-stone-200 text-base sm:text-lg leading-relaxed">
                    To be a cultural reference in Latin America for its ethical and contemporary practice in living heritage activation.
                </p>
            </div>
            <div class="bg-soil-raised p-5 sm:p-7 rounded-xl" data-animate>
                <h3 class="text-xl sm:text-2xl font-display font-bold text-clay-400 mb-3">Mission</h3>
                <p class="text-stone-200 text-base sm:text-lg leading-relaxed">
                    To activate ancestral knowledge through cultural mediation that integrates creation, writing, and education from the territory.
                </p>
            </div>
        </div>
    </section>

    <!-- Valores -->
    <section class="py-10 sm:py-14 md:py-16 bg-soil-mid rounded-xl px-5 sm:px-6">
        <SectionTitle 
            title="Our Perspective"
            subtitle="The philosophy that defines every decision."
        />
        
        <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 mt-8 sm:mt-10">
            {values.map((value, index) => (
                <div 
                    class="bg-soil-raised p-5 sm:p-6 rounded-xl text-center animate-value"
                    data-index={index}
                >
                    <span class="text-4xl sm:text-5xl mb-4 block">{value.icon}</span>
                    <h3 class="text-base sm:text-lg font-display font-bold text-white mb-2">{value.title}</h3>
                    <p class="text-stone-400 text-sm sm:text-base leading-relaxed">{value.description}</p>
                </div>
            ))}
        </div>
    </section>

    <!-- Impulsor -->
    <section class="py-10 sm:py-14 md:py-16">
        <SectionTitle 
            title="Promoter"
            subtitle="The person behind Ancestral Lab."
        />
        
        <div class="max-w-sm sm:max-w-md md:max-w-lg mx-auto">
            <div class="bg-soil-raised rounded-xl overflow-hidden" data-animate>
                <div class="relative h-48 sm:h-56 overflow-hidden">
                    <img 
                        src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&q=80"
                        alt="Yaku Heredia"
                        class="w-full h-full object-cover"
                    />
                </div>
                <div class="p-5 sm:p-6 text-center">
                    <h3 class="text-xl sm:text-2xl font-display font-bold text-white mb-2">Yaku Heredia</h3>
                    <p class="text-clay-400 font-semibold uppercase text-xs sm:text-sm tracking-wider mb-3">Cultural Mediator and Visual Narrator</p>
                    <p class="text-stone-300 text-base sm:text-lg leading-relaxed">
                        Their work integrates creation, education, and communication with community ethics.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-10 sm:py-14 md:py-16 bg-clay-600 rounded-xl px-5 sm:px-6">
        <div class="text-center">
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-display font-bold text-white mb-4">
                Want to explore co-creation possibilities?
            </h2>
            <p class="text-white/80 text-base sm:text-lg mb-8 max-w-xl mx-auto">
                Contact us to start a dialogue from the territory.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center max-w-md mx-auto">
                <a href="/en/contacto/" class="inline-block bg-soil-void hover:bg-soil-deep text-white font-semibold uppercase text-sm tracking-wider px-8 py-4 rounded-full transition-all hover:scale-105">
                    Write to Us
                </a>
                <a href="/en/servicios/" class="inline-block bg-transparent border-2 border-white hover:bg-white hover:text-clay-600 text-white font-semibold uppercase text-sm tracking-wider px-8 py-4 rounded-full transition-all hover:scale-105">
                    View Services
                </a>
            </div>
        </div>
    </section>
</Layout>

<script>
    const animateOnScroll = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('[data-animate]').forEach((el) => {
        animateOnScroll.observe(el);
    });

    document.querySelectorAll('.animate-value').forEach((el, index) => {
        (el as HTMLElement).style.transitionDelay = `${index * 100}ms`;
        animateOnScroll.observe(el);
    });
</script>

<style>
    [data-animate] {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.5s ease-out, transform 0.5s ease-out;
    }
    [data-animate].visible {
        opacity: 1;
        transform: translateY(0);
    }

    .animate-value {
        opacity: 0;
        transform: translateY(15px);
        transition: opacity 0.4s ease-out, transform 0.4s ease-out;
    }
    .animate-value.visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>
