    <nav class="footer__links" aria-label="Footer navegación">
      <div class="footer__col">
        <span class="footer__col-title" data-i18n="footer.servicios">Servicios</span>
        <a href="#servicios" class="footer__link" data-i18n="footer.desarrolloWeb">Desarrollo Web</a>
        <a href="#servicios" class="footer__link" data-i18n="footer.ecommerce">E-commerce</a>
        <a href="#servicios" class="footer__link" data-i18n="footer.panelesAdmin">Paneles Admin</a>
        <a href="#servicios" class="footer__link" data-i18n="footer.chatbots">Chatbots</a>
      </div>
      <div class="footer__col">
        <span class="footer__col-title" data-i18n="footer.empresa">Empresa</span>
        <a href="#proceso" class="footer__link" data-i18n="footer.proceso">Proceso</a>
        <a href="#proyectos" class="footer__link" data-i18n="footer.proyectos">Proyectos</a>
        <a href="#contacto" class="footer__link" data-i18n="footer.contacto">Contacto</a>
      </div>
      <div class="footer__col">
        <span class="footer__col-title" data-i18n="footer.legal">Legal</span>
        <a href="#" class="footer__link" data-i18n="footer.terminos">Términos</a>
        <a href="#" class="footer__link" data-i18n="footer.privacidad">Privacidad</a>
      </div>
    </nav>
  </div>

  <div class="container footer__bottom">
    <p class="footer__legal">
      <span data-i18n="footer.copyright">MIT License —</span> &copy; {new Date().getFullYear()} Monkey Computer
    </p>

    <p class="footer__legal footer__right" data-i18n="footer.madeWith">
      Hecho con 💜.
    </p>
  </div>
</footer>

<style>
  .footer {
    padding-top: 0;
    padding-bottom: 2rem;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    padding-block: 3rem;
    align-items: start;
  }

  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .footer__logo:hover { opacity: 0.7; }

  .footer__tagline {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: 0.35rem;
  }

  .footer__credit {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .footer__dot {
    color: var(--accent);
    margin-right: 0.25rem;
  }

  .footer__links {
    display: flex;
    gap: 3rem;
  }

  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__col-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    margin-bottom: 0.25rem;
  }

  .footer__link {
    font-size: 0.875rem;
    color: var(--text-muted);
    transition: color 0.2s;
    text-decoration: none;
  }

  .footer__link:hover { color: var(--text-primary); }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-subtle);
  }

  .footer__legal {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .footer__legal a {
    color: var(--text-muted);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    transition: color 0.2s;
    text-decoration: none;
  }

  .footer__legal a:hover { color: var(--text-secondary); }

  .footer__social {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 25px;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6b7280;
    transition: color 0.2s;
    text-decoration: none;
  }

  .footer__social-link:hover { color: #9ca3af; }

  @media (max-width: 900px) {
    .footer__inner {
      grid-template-columns: 1fr;
    }

    .footer__links {
      flex-wrap: wrap;
      gap: 2rem;
    }
  }

  @media (max-width: 480px) {
    .footer__bottom {
      flex-direction: column;
      gap: 0.75rem;
      align-items: center;
      text-align: center;
    }
  }
</style>
