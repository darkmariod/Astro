---
interface Props {
    title: string;
    subtitle?: string;
    align?: "left" | "center";
}

const { title, subtitle, align = "center" } = Astro.props;
---

<div 
    class={`mb-10 sm:mb-14 md:mb-18 animate-section-title ${align === "center" ? "text-center" : ""}`}
    data-animate
>
    <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-display font-bold text-white relative inline-block tracking-tight leading-[1.1]">
        {title}
        <span class="block h-1.5 bg-clay-600 mt-4 sm:mt-6 w-16 sm:w-20 md:w-24"></span>
    </h2>
    {subtitle && (
        <p class="mt-6 sm:mt-8 text-stone-300 text-base sm:text-lg md:text-xl max-w-3xl mx-auto px-4 leading-relaxed">
            {subtitle}
        </p>
    )}
</div>

<style>
    .animate-section-title {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.7s ease-out, transform 0.7s ease-out;
    }

    .animate-section-title.visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>
