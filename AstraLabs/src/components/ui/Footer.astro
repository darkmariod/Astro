---
import FooterBox from "./FooterBox.astro";
---

<footer class="bg-soil-void pt-14 pb-8">
    <div class="max-w-5xl mx-auto px-5 grid grid-cols-1 sm:grid-cols-2 gap-8">
        <FooterBox heading="Ubicación">
            <p>Av. Principal 123 y Calle Secundaria</p>
            <p>Ecuador</p>
        </FooterBox>
        <FooterBox heading="Contacto">
            <p>+593 99 123 4567</p>
            <p>info@astralab.com</p>
            <p>Lun - Vie: 8:00 - 18:00</p>
        </FooterBox>
    </div>
    <div class="max-w-5xl mx-auto px-5 mt-10 pt-6 border-t border-soil-raised">
        <p class="text-center text-stone-400 text-sm">
            Todos los derechos reservados Astra Lab, © {
                new Date().getFullYear()
            }
        </p>
    </div>
</footer>
