---
---

<section class="hero" id="inicio">
  <div class="hero__bg" aria-hidden="true"></div>

  <div class="container">
    <div class="hero__center">
      <!-- Badge simple -->
      <div class="hero__badge reveal">
        <span data-i18n="hero.badge">Desarrollo de Software</span>
      </div>

      <!-- Title directo -->
      <h1 class="display-xl hero__title reveal">
        <span data-i18n="hero.title">Creamos el ecositema,</span><br/>
        <span class="gradient-text" data-i18n="hero.titleAccent">digital que necesita tu empresa.</span>
      </h1>



      <!-- CTAs -->
      <div class="hero__actions reveal">
        <a href="#contacto" class="btn btn-primary btn-lg btn-hero">
          <span>Cotizar</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
          </svg>
        </a>
        <a href="#proyectos" class="btn btn-secondary btn-lg btn-hero">
          <span>Proyectos</span>
        </a>
      </div>
    </div>
  </div>
</section>
