---
// Hero section
---

<section class="hero noise-overlay" id="hero">
  <div class="hero__orb" aria-hidden="true"></div>
  <div class="hero__orb hero__orb--secondary" aria-hidden="true"></div>
  <div class="hero__grid" aria-hidden="true"></div>

  <div class="hero__content container">
    <div class="hero__center">
      <div class="hero__badge eyebrow reveal reveal-delay-1">
        <span class="hero__badge-dot" aria-hidden="true"></span>
        <span>Freelancer · Desarrollo de Software</span>
      </div>

      <h1 class="display-xl hero__headline reveal reveal-delay-2">
        <span class="hero__headline-line">Construyo</span>
        <span class="hero__headline-line gradient-text">software que funciona.</span>
      </h1>

      <p class="hero__sub reveal reveal-delay-3">
        Páginas web, tiendas online, paneles de administración y chatbots.
        Soluciones a medida para tu negocio, sin intermediarios.
      </p>

      <div class="hero__actions reveal reveal-delay-4">
        <a href="#contacto" class="btn btn-primary btn-lg">
          <span>Pedir presupuesto</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M8 1v10M3 7l5 5 5-5M1 13h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#proyectos" class="btn btn-secondary btn-lg">
          Ver proyectos
        </a>
      </div>

      <div class="hero__services-row reveal reveal-delay-5">
        <span class="hero__service-chip">🌐 Páginas Web</span>
        <span class="hero__service-chip">🛒 Tiendas Online</span>
        <span class="hero__service-chip">⚙️ Paneles Admin</span>
        <span class="hero__service-chip">🤖 Chatbots</span>
      </div>
    </div>
  </div>
</section>