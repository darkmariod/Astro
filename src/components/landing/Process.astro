---
// FAQ - Preguntas frecuentes
const faqs = [
  { 
    question: "¿Cuánto tiempo tarda un proyecto?", 
    answer: "Depende de la complejidad. Un landing page toma 5-7 días, tiendas online 2-3 semanas, y proyectos a medida 1-3 meses."
  },
  { 
    question: "¿Necesito tener todo definido?", 
    answer: "No, solo con tu idea y objetivo basta. Te ayudo a cristalizar los detalles en la primera reunión sin costo."
  },
  { 
    question: "¿Qué incluye el precio?", 
    answer: "Todo: diseño, desarrollo, hosting por 1 año, SSL, y 30 días de soporte post-entrega."
  },
  { 
    question: "¿Puedo modificar después?", 
    answer: "Sí, durante el desarrollo tienes cambios ilimitados. Post-entrega, cambios menores gratis por 30 días."
  },
  { 
    question: "¿Cómo funciona el pago?", 
    answer: "50% para comenzar y 50% al entrega. Aceptamos transferencia, MercadoPago y USDT."
  },
];
---

<section class="process section" id="proceso">
  <div class="container">
    <div class="process__header reveal">
      <p class="eyebrow">FAQ</p>
      <h2 class="display-lg">Preguntas<span class="gradient-text"> Frecuentes</span></h2>
    </div>

    <!-- FAQ Accordion -->
    <div class="faq">
      {faqs.map((faq, i) => (
        <details class="faq__item" open={i === 0}>
          <summary class="faq__question">
            <span>{faq.question}</span>
            <svg class="faq__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </summary>
          <p class="faq__answer">{faq.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .process {
    background: var(--bg-surface);
  }

  .process__header {
    text-align: center;
    margin-bottom: clamp(3rem, 5vw, 4rem);
  }

  .process__header h2 {
    margin-top: 1rem;
  }

  /* FAQ Accordion Styles */
  .faq {
    max-width: 700px;
    margin-inline: auto;
  }

  .faq__item {
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: 0.75rem;
    margin-bottom: 0.75rem;
    overflow: hidden;
  }

  .faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem;
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--text-primary);
    cursor: pointer;
    list-style: none;
    transition: background 0.2s;
  }

  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__question:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  .faq__icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: var(--accent);
    transition: transform 0.25s ease;
  }

  details[open] .faq__icon {
    transform: rotate(180deg);
  }

  .faq__answer {
    padding: 0 1.25rem 1.25rem;
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }
</style>