---
// Footer simplificado
---

<footer class="footer">
  <div class="divider"></div>
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="/" class="footer__logo">
        <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
          <circle cx="16" cy="16" r="14" stroke="#6366f1" stroke-width="2"/>
          <circle cx="11" cy="12" r="3" fill="#6366f1"/>
          <circle cx="21" cy="12" r="3" fill="#6366f1"/>
          <path d="M9 22c0-3 2-5 5-5s5 2 5 5" stroke="#6366f1" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <span>Monkey Computer</span>
      </a>
      <p class="footer__tagline">Desarrollo de software a medida</p>
    </div>

    <nav class="footer__links" aria-label="Footer navegación">
      <a href="#servicios" class="footer__link">Servicios</a>
      <a href="#proceso" class="footer__link">Proceso</a>
      <a href="#proyectos" class="footer__link">Proyectos</a>
      <a href="#contacto" class="footer__link">Contacto</a>
    </nav>
  </div>

  <div class="container footer__bottom">
    <p class="footer__legal">
      &copy; {new Date().getFullYear()} Monkey Computer. Todos los derechos reservados.
    </p>
  </div>
</footer>