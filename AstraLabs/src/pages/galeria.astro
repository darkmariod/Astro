---
import Layout from "@/layouts/Layout.astro";
import bg from "@/assets/bg_home.jpg";

const galleryImages = [
    {
        id: 1,
        src: "https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=800&q=80",
        alt: "Trabajo territorial con comunidades",
        title: "Trabajo Territorial"
    },
    {
        id: 2,
        src: "https://images.unsplash.com/photo-1460661419201-fd4cecdf8a8b?w=800&q=80",
        alt: "Documentación de saberes",
        title: "Documentación de Saberes"
    },
    {
        id: 3,
        src: "https://images.unsplash.com/photo-1531058020387-3be344556be6?w=800&q=80",
        alt: "Laboratorio cultural",
        title: "Laboratorio Cultural"
    },
    {
        id: 4,
        src: "https://images.unsplash.com/photo-1456324504439-367cee3b3c32?w=800&q=80",
        alt: "Taller de narrativa",
        title: "Taller de Narrativa"
    },
    {
        id: 5,
        src: "https://images.unsplash.com/photo-1492725764893-90b379c2b6e7?w=800&q=80",
        alt: "Archivo comunitario",
        title: "Archivo Comunitario"
    },
    {
        id: 6,
        src: "https://images.unsplash.com/photo-1469474968028-56623f02e42e?w=800&q=80",
        alt: "Paisaje cultural",
        title: "Paisaje Cultural"
    }
];

// URL de PayPal (reemplazar con tu link real)
const PAYPAL_LINK = "https://www.paypal.com/donate";
const WHATSAPP_NUMBER = "593991234567";
---

<Layout title="Galería" subtitle="Donar" bgImage={bg.src}>
    
    <!-- Info -->
    <section class="text-center px-5 py-10 sm:py-12" data-animate>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-white mb-4">
            Galería de Imágenes
        </h1>
        <p class="text-stone-300 text-lg sm:text-xl max-w-2xl mx-auto mb-5 leading-relaxed">
            Apoya nuestro trabajo de activación patrimonial. Elige una imagen, dona lo que puedas y recibe tu link de descarga.
        </p>
        <div class="inline-flex items-center gap-2 bg-soil-raised px-5 py-3 rounded-full">
            <span class="text-xl">💚</span>
            <span class="text-stone-200 text-base sm:text-lg">Donación voluntaria • Sin precio fijo</span>
        </div>
    </section>

    <!-- Grid de Imágenes -->
    <section class="mb-10 sm:mb-14 px-5">
        <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5" id="gallery-grid">
            {galleryImages.map((img) => (
                <div class="gallery-item group cursor-pointer" data-id={img.id} data-title={img.title}>
                    <div class="relative h-48 sm:h-52 lg:h-56 overflow-hidden rounded-xl">
                        <img 
                            src={img.src}
                            alt={img.alt}
                            class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                            loading="lazy"
                        />
                        <div class="absolute inset-0 bg-soil-void/70 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                            <span class="text-white font-semibold text-sm px-4 py-2 bg-clay-600 rounded-full">
                                Ver opciones
                            </span>
                        </div>
                    </div>
                    <h3 class="text-base sm:text-lg text-stone-200 mt-3 text-center">{img.title}</h3>
                </div>
            ))}
        </div>
    </section>

    <!-- Modal de Donación -->
    <div id="donation-modal" class="fixed inset-0 bg-soil-void/95 z-50 hidden items-center justify-center p-4 overflow-y-auto">
        <div class="bg-soil-raised rounded-2xl max-w-md w-full p-6 sm:p-7 relative my-8">
            <button id="close-modal" class="absolute top-4 right-4 w-10 h-10 flex items-center justify-center text-stone-400 hover:text-white rounded-full hover:bg-soil-mid transition-colors">
                <span class="text-2xl">&times;</span>
            </button>
            
            <div id="modal-content">
                <img id="modal-image" src="" alt="" class="w-full h-48 sm:h-56 object-cover rounded-xl mb-5" />
                <h3 id="modal-title" class="text-xl sm:text-2xl font-display font-bold text-white mb-4"></h3>
                
                <!-- Phase 1: Amount Selection -->
                <div id="phase-amount" class="mb-4">
                    <p class="text-stone-300 text-base sm:text-lg mb-5">
                        Selecciona un monto para tu donación voluntaria:
                    </p>
                    <div class="grid grid-cols-3 gap-3 mb-5">
                        <button class="amount-btn w-full py-4 bg-soil-mid hover:bg-clay-600 text-white font-semibold rounded-xl transition-colors text-lg" data-amount="5">$5</button>
                        <button class="amount-btn w-full py-4 bg-soil-mid hover:bg-clay-600 text-white font-semibold rounded-xl transition-colors text-lg" data-amount="10">$10</button>
                        <button class="amount-btn w-full py-4 bg-soil-mid hover:bg-clay-600 text-white font-semibold rounded-xl transition-colors text-lg" data-amount="15">$15</button>
                        <button class="amount-btn w-full py-4 bg-soil-mid hover:bg-clay-600 text-white font-semibold rounded-xl transition-colors text-lg" data-amount="25">$25</button>
                        <button class="amount-btn w-full py-4 bg-soil-mid hover:bg-clay-600 text-white font-semibold rounded-xl transition-colors text-lg" data-amount="50">$50</button>
                        <button class="amount-btn w-full py-4 bg-soil-mid hover:bg-clay-600 text-white font-semibold rounded-xl transition-colors text-lg" data-amount="100">$100</button>
                    </div>
                    <p class="text-stone-500 text-sm text-center">
                        Después de donar, envía tu comprobante por WhatsApp para recibir el link de descarga.
                    </p>
                </div>
                
                <!-- Phase 2: Payment Methods -->
                <div id="phase-payment" class="hidden space-y-3">
                    <button 
                        id="back-btn"
                        class="text-stone-400 hover:text-white text-sm flex items-center gap-2 mb-2"
                    >
                        ← Volver
                    </button>
                    
                    <p class="text-stone-300 text-base sm:text-lg mb-4">
                        Has seleccionado <span id="selected-amount" class="text-clay-400 font-bold text-xl"></span>. Ahora elige cómo realizar tu donación:
                    </p>
                    
                    <a 
                        id="paypal-btn"
                        href={PAYPAL_LINK}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex items-center justify-center gap-2 w-full bg-[#0070ba] hover:bg-[#005ea6] text-white font-bold py-4 px-4 rounded-xl transition-colors text-lg"
                    >
                        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-3.221 0-4.98.915-5.965 2.12-.706.906-1.053 2.07-.968 3.253.094 1.3.532 2.3 1.57 3.18.44.373.99.647 1.574.82.56.165 1.16.25 1.73.25.45 0 .87-.05 1.246-.14.45-.109.836-.264 1.19-.44l.17-.086h.01z"/>
                        </svg>
                        Donar con PayPal
                    </a>
                    
                    <a 
                        id="whatsapp-btn"
                        href="#"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex items-center justify-center gap-2 w-full bg-[#25D366] hover:bg-[#1fb855] text-white font-bold py-4 px-4 rounded-xl transition-colors text-lg"
                    >
                        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                        </svg>
                        Enviar por WhatsApp
                    </a>
                    
                    <p class="text-stone-500 text-sm mt-4 text-center">
                        Después de donate, envía tu comprobante por WhatsApp para recibir el link de descarga.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Info adicional -->
    <section class="py-10 sm:py-12 bg-soil-mid rounded-xl mx-5 mb-8" data-animate>
        <div class="max-w-xl mx-auto px-5 text-center">
            <h2 class="text-xl sm:text-2xl font-display font-bold text-white mb-6">¿Cómo funciona?</h2>
            <div class="grid grid-cols-3 gap-4 sm:gap-6 text-center">
                <div class="p-4 sm:p-5">
                    <span class="text-4xl sm:text-5xl">1️⃣</span>
                    <p class="text-stone-300 text-base sm:text-lg mt-3">Elige la imagen</p>
                </div>
                <div class="p-4 sm:p-5">
                    <span class="text-4xl sm:text-5xl">2️⃣</span>
                    <p class="text-stone-300 text-base sm:text-lg mt-3">Dona lo que puedas</p>
                </div>
                <div class="p-4 sm:p-5">
                    <span class="text-4xl sm:text-5xl">3️⃣</span>
                    <p class="text-stone-300 text-base sm:text-lg mt-3">Recibe el link</p>
                </div>
            </div>
        </div>
    </section>
</Layout>

<script>
    const WHATSAPP_NUMBER = "593991234567";
    const PAYPAL_LINK = "https://www.paypal.com/donate";
    
    const modal = document.getElementById('donation-modal');
    const modalImage = document.getElementById('modal-image') as HTMLImageElement;
    const modalTitle = document.getElementById('modal-title');
    const paypalBtn = document.getElementById('paypal-btn') as HTMLAnchorElement;
    const whatsappBtn = document.getElementById('whatsapp-btn') as HTMLAnchorElement;
    const closeBtn = document.getElementById('close-modal');
    const phaseAmount = document.getElementById('phase-amount');
    const phasePayment = document.getElementById('phase-payment');
    const selectedAmountSpan = document.getElementById('selected-amount');
    const backBtn = document.getElementById('back-btn');
    
    let currentImgTitle = '';
    let currentAmount = '10';
    
    document.querySelectorAll('.gallery-item').forEach((item) => {
        item.addEventListener('click', () => {
            const imgSrc = item.querySelector('img')?.src || '';
            currentImgTitle = item.getAttribute('data-title') || '';
            
            if (modalImage) modalImage.src = imgSrc;
            if (modalTitle) modalTitle.textContent = currentImgTitle;
            
            phaseAmount?.classList.remove('hidden');
            phasePayment?.classList.add('hidden');
            currentAmount = '10';
            
            modal?.classList.remove('hidden');
            modal?.classList.add('flex');
        });
    });
    
    document.querySelectorAll('.amount-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.amount-btn').forEach(b => {
                b.classList.remove('bg-clay-600');
                b.classList.add('bg-soil-mid');
            });
            btn.classList.remove('bg-soil-mid');
            btn.classList.add('bg-clay-600');
            
            currentAmount = btn.getAttribute('data-amount') || '10';
            
            if (selectedAmountSpan) selectedAmountSpan.textContent = `$${currentAmount}`;
            
            if (paypalBtn) {
                paypalBtn.href = `${PAYPAL_LINK}?amount=${currentAmount}&currency=USD`;
            }
            
            if (whatsappBtn) {
                const message = encodeURIComponent(
                    `Hola! Quiero descargar la imagen: "${currentImgTitle}"\n` +
                    `He realizado una donación de $${currentAmount} USD.\n\n` +
                    `Por favor envíame el link de descarga.`
                );
                whatsappBtn.href = `https://wa.me/${WHATSAPP_NUMBER}?text=${message}`;
            }
            
            phaseAmount?.classList.add('hidden');
            phasePayment?.classList.remove('hidden');
        });
    });
    
    backBtn?.addEventListener('click', () => {
        phaseAmount?.classList.remove('hidden');
        phasePayment?.classList.add('hidden');
    });
    
    closeBtn?.addEventListener('click', () => {
        modal?.classList.add('hidden');
        modal?.classList.remove('flex');
    });
    
    modal?.addEventListener('click', (e) => {
        if (e.target === modal) {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }
    });
    
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            modal?.classList.add('hidden');
            modal?.classList.remove('flex');
        }
    });
    
    const animateOnScroll = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('[data-animate]').forEach((el) => {
        animateOnScroll.observe(el);
    });
</script>

<style>
    [data-animate] {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.5s ease-out, transform 0.5s ease-out;
    }
    [data-animate].visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>
