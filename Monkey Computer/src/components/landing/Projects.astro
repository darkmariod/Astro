---
// Proyectos como "Casos de Éxito" - estilo Ryze
// Estructura: problema → solución → resultado
---

<section class="projects section" id="proyectos">
  <div class="container">
    <div class="projects__header reveal">
      <p class="eyebrow">Casos de Éxito</p>
      <h2 class="display-lg">
        <span>Proyectos que</span><br/>
        <span class="gradient-text">generan resultados.</span>
      </h2>
    </div>

    <div class="cases__grid">
      <!-- Caso 1: E-commerce -->
      <a href="#contacto" class="case-card reveal">
        <!-- IMAGEN: Reemplaza la URL abajo con tu imagen -->
        <div class="case-card__image" style="background-image: url('https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=600&h=300&fit=crop')"></div>
        
        <div class="case-card__header">
          <span class="case-card__tag">E-commerce</span>
        </div>
        <h3 class="case-card__client">Natufitnes</h3>
        
        <div class="case-card__content">
          <div class="case-item">
            <span class="case-item__label">Problema</span>
            <p>Necesitaba vender online con gestión de inventario automática</p>
          </div>
          <div class="case-item">
            <span class="case-item__label">Solución</span>
            <p>Tienda online con panel administrativo y pagos integrados</p>
          </div>
          <div class="case-item case-item__result">
            <span class="case-item__label">Resultado</span>
            <p>tienda funcionando 24/7 con pedidos automatizados</p>
          </div>
        </div>
      </a>

      <!-- Caso 2: Dashboard -->
      <a href="#contacto" class="case-card reveal reveal-delay-1">
        <!-- IMAGEN: Reemplaza la URL abajo con tu imagen -->
        <div class="case-card__image" style="background-image: url('https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&h=300&fit=crop')"></div>
        
        <div class="case-card__header">
          <span class="case-card__tag">Sistema</span>
        </div>
        <h3 class="case-card__client">Dashboard SaaS</h3>
        
        <div class="case-card__content">
          <div class="case-item">
            <span class="case-item__label">Problema</span>
            <p>Control de inventario en tiempo real para arquitectos</p>
          </div>
          <div class="case-item">
            <span class="case-item__label">Solución</span>
            <p>Panel de control con métricas y alertas automáticas</p>
          </div>
          <div class="case-item case-item__result">
            <span class="case-item__label">Resultado</span>
            <p>gestión centralizada con información actualizada</p>
          </div>
        </div>
      </a>

      <!-- Caso 3: Chatbot -->
      <a href="#contacto" class="case-card reveal reveal-delay-2">
        <!-- IMAGEN: Reemplaza la URL abajo con tu imagen -->
        <div class="case-card__image" style="background-image: url('https://images.unsplash.com/photo-1553484771-371a605b060b?w=600&h=300&fit=crop')"></div>
        
        <div class="case-card__header">
          <span class="case-card__tag">Chatbot</span>
        </div>
        <h3 class="case-card__client">WhatsApp Bot</h3>
        
        <div class="case-card__content">
          <div class="case-item">
            <span class="case-item__label">Problema</span>
            <p>Atención al cliente 24/7 sin depender de personas</p>
          </div>
          <div class="case-item">
            <span class="case-item__label">Solución</span>
            <p>Bot conectado a WhatsApp con IA para responder consultas</p>
          </div>
          <div class="case-item case-item__result">
            <span class="case-item__label">Resultado</span>
            <p>atención automatizada respondiendo clientes las 24 horas</p>
          </div>
        </div>
      </a>

      <!-- Caso 4: Web -->
      <a href="#contacto" class="case-card reveal reveal-delay-3">
        <!-- IMAGEN: Reemplaza la URL abajo con tu imagen -->
        <div class="case-card__image" style="background-image: url('https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600&h=300&fit=crop')"></div>
        
        <div class="case-card__header">
          <span class="case-card__tag">Web</span>
        </div>
        <h3 class="case-card__client">Agencia Turismo</h3>
        
        <div class="case-card__content">
          <div class="case-item">
            <span class="case-item__label">Problema</span>
            <p>Captar turistas desde Google sin presencia digital</p>
          </div>
          <div class="case-item">
            <span class="case-item__label">Solución</span>
            <p>Web optimizada para SEO con diseño premium</p>
          </div>
          <div class="case-item case-item__result">
            <span class="case-item__label">Resultado</span>
            <p>web visible en Google atrayendo clientes</p>
          </div>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  .projects {
    background: var(--bg-surface);
    padding: var(--section-py) 0;
  }

  .projects__header {
    text-align: center;
    margin-bottom: clamp(2rem, 5vw, 3rem);
  }

  .projects__header h2 span:first-child {
    display: block;
  }

  @media (min-width: 768px) {
    .projects__header h2 span:first-child {
      display: inline;
    }
  }

  /* Grid 2x2 estilo casos */
  .cases__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    max-width: 800px;
    margin-inline: auto;
  }

  @media (min-width: 640px) {
    .cases__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Case Card - estilo Ryze */
  .case-card {
    display: block;
    padding: 0;
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: 1rem;
    text-decoration: none;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .case-card:hover {
    transform: translateY(-4px) scale(1.02);
    border-color: var(--accent);
    box-shadow: 0 20px 40px rgba(192, 132, 252, 0.15);
  }

  /* Imagen del caso - editable desde código */
  .case-card__image {
    width: 100%;
    height: 160px;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .case-card__info {
    padding: 1.5rem;
  }

  .case-card__header {
    margin-bottom: 0.75rem;
  }

  .case-card__tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: var(--accent-soft);
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--accent);
  }

  .case-card__client {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1rem;
    padding: 0 1.5rem;
  }

  .case-card__content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .case-item__label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
    padding: 0 1.5rem;
  }

  .case-item p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.4;
    padding: 0 1.5rem;
  }

  .case-item__result {
    padding: 0.75rem 1.5rem 1.5rem;
    margin-top: 0.5rem;
    border-top: 1px solid var(--border-subtle);
  }

  .case-item__result p {
    padding: 0;
  }

  .case-item__result .case-item__label {
    color: var(--accent);
  }

  .case-item__result p {
    color: var(--text-primary);
    font-weight: 500;
  }
</style>