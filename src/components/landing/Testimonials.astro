---
// Testimonials - testimonios de clientes
const testimonials = [
  {
    quote: "Excelente trabajo. Entregó antes de lo esperado y con calidad superior a lo pactado.",
    name: "Juan Pérez",
    role: "Director, TechStart"
  },
  {
    quote: "Entendió exactamente lo que necesitaba. El chatbot incrementó nuestro soporte en un 40%.",
    name: "María González",
    role: "CEO, E-comerce"
  }
];
---

<section class="testimonials section">
  <div class="container">
    <div class="testimonials__header reveal">
      <p class="eyebrow">Testimonios</p>
      <h2 class="display-lg">Lo que<span class="gradient-text">dicen.</span></h2>
    </div>

    <div class="testimonials__grid">
      {testimonials.map((t, i) => (
        <div class={`card testimonial-card reveal reveal-delay-${i + 1}`}>
          <blockquote class="testimonial-card__quote">"{t.quote}"</blockquote>
          <div class="testimonial-card__author">
            <strong>{t.name}</strong>
            <span>{t.role}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>