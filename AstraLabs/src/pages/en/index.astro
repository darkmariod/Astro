---
import Layout from "@/layouts/Layout.astro";
import bg from "@/assets/bg_home.jpg";
import Card from "@/components/ui/Card.astro";
import SectionTitle from "@/components/ui/SectionTitle.astro";

const servicios = [
    {
        title: "Cultural Laboratories",
        description: "Spaces for creation and experimentation where living heritage meets contemporary proposals.",
        image: "https://images.unsplash.com/photo-1531058020387-3be344556be6?w=800&q=80",
        category: "Service",
        link: "/en/servicios/"
    },
    {
        title: "Mediation and Visual Narrative",
        description: "Workshops to learn how to document and tell stories from an ethical and community perspective.",
        image: "https://images.unsplash.com/photo-1456324504439-367cee3b3c32?w=800&q=80",
        category: "Workshop",
        link: "/en/servicios/"
    },
    {
        title: "Ethical Documentation",
        description: "Processes of registration and archiving that respect communities' sovereignty over their knowledge.",
        image: "https://images.unsplash.com/photo-1460661419201-fd4cecdf8a8b?w=800&q=80",
        category: "Service",
        link: "/en/servicios/"
    }
];

const metodology = [
    {
        moment: "01",
        title: "Territorial Listening",
        description: "Recognition, dialogue, and building bonds with communities and the territory."
    },
    {
        moment: "02",
        title: "Sensitive Research",
        description: "Learning from experience, the body, and words."
    },
    {
        moment: "03",
        title: "Creation and Mediation",
        description: "Visual, written processes, and cultural laboratories."
    },
    {
        moment: "04",
        title: "Return and Circulation",
        description: "Community socialization and conscious archiving."
    }
];
---

< Layout title="Home" subtitle="Ancestral Lab" bgImage={bg.src}>
    
    <!-- Hero Section -->
    <section class="text-center px-4 py-16 sm:py-20 md:py-24" data-animate>
        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-display font-bold text-white mb-6 sm:mb-8 leading-[1.1] tracking-tight">
            Living Heritage<br />
            <span class="text-clay-400">Activation</span>
        </h1>
        <p class="text-stone-300 text-lg sm:text-xl md:text-2xl max-w-3xl mx-auto mb-8 sm:mb-10 px-2 leading-relaxed">
            Cultural and methodological platform dedicated to the activation of living heritage and ancestral knowledge from the territory.
        </p>
        <a href="/en/nosotros/" class="inline-block bg-clay-600 hover:bg-clay-700 text-white font-semibold uppercase text-sm sm:text-base tracking-wider px-8 sm:px-10 py-4 sm:py-5 rounded-full transition-all hover:scale-105">
            Learn Our Methodology
        </a>
    </section>

    <!-- Propósito -->
    <section class="py-16 sm:py-20 md:py-24 border-t border-soil-raised">
        <div class="max-w-6xl mx-auto px-5">
            <SectionTitle 
                title="Our Perspective"
                subtitle="Culture is a living body in constant transformation, not something static for museums."
                align="center"
            />
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mt-10 sm:mt-14">
                <div class="bg-soil-raised p-6 sm:p-8 rounded-xl text-center" data-animate>
                    <div class="text-4xl sm:text-5xl mb-5">🌱</div>
                    <h3 class="text-xl sm:text-2xl font-display font-bold text-white mb-4">Heritage in Practice</h3>
                    <p class="text-stone-300 text-base sm:text-lg leading-relaxed">
                        It's preserved in everyday life: trades, words, images, and relationship with the territory.
                    </p>
                </div>
                <div class="bg-soil-raised p-6 sm:p-8 rounded-xl text-center" data-animate>
                    <div class="text-4xl sm:text-5xl mb-5">🤝</div>
                    <h3 class="text-xl sm:text-2xl font-display font-bold text-white mb-4">Contemporary Dialogue</h3>
                    <p class="text-stone-300 text-base sm:text-lg leading-relaxed">
                        We work with ancestral knowledge without folklorizing it, recognizing communities as active subjects.
                    </p>
                </div>
                <div class="bg-soil-raised p-6 sm:p-8 rounded-xl text-center md:col-span-1" data-animate>
                    <div class="text-4xl sm:text-5xl mb-5">🛡️</div>
                    <h3 class="text-xl sm:text-2xl font-display font-bold text-white mb-4">Non-Extraction</h3>
                    <p class="text-stone-300 text-base sm:text-lg leading-relaxed">
                        We're not an extractive or superficial project. Knowledge is shared, not extracted.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Metodología -->
    <section class="py-16 sm:py-20 md:py-24 bg-soil-mid">
        <div class="max-w-6xl mx-auto px-5">
            <SectionTitle 
                title="Ancestral Lab Methodology"
                subtitle="Four moments to activate living heritage in an ethical and community-based way."
            />
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mt-10 sm:mt-14">
                {metodology.map((step, index) => (
                    <div 
                        class="relative bg-soil-raised p-6 sm:p-8 rounded-xl border-l-4 border-clay-600 animate-method"
                        data-index={index}
                    >
                        <span class="text-5xl sm:text-6xl md:text-7xl font-display font-bold text-clay-600/20 absolute top-4 right-4 sm:top-6 sm:right-6">
                            {step.moment}
                        </span>
                        <h3 class="text-xl sm:text-2xl font-display font-bold text-white mb-4 relative z-10">
                            {step.title}
                        </h3>
                        <p class="text-stone-300 text-sm sm:text-base leading-relaxed relative z-10">
                            {step.description}
                        </p>
                    </div>
                ))}
            </div>
            
            <p class="text-center text-clay-400 mt-8 sm:mt-10 italic font-display text-base sm:text-lg px-4">
                "Nothing is published without return. Nothing is created without listening."
            </p>
        </div>
    </section>

    <!-- Servicios -->
    <section class="py-16 sm:py-20 md:py-24">
        <div class="max-w-6xl mx-auto px-5">
            <SectionTitle 
                title="Our Lines of Work"
                subtitle="Processes of creation, cultural mediation, education, and ethical communication."
            />
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6 mt-10 sm:mt-14">
                {servicios.map((item, index) => (
                    <Card 
                        title={item.title}
                        description={item.description}
                        image={item.image}
                        category={item.category}
                        link={item.link}
                        index={index}
                    />
                ))}
            </div>
        </div>
    </section>

    <!-- Quiénes trabajamos -->
    <section class="py-16 sm:py-20 md:py-24 bg-soil-mid">
        <div class="max-w-6xl mx-auto px-5">
            <SectionTitle 
                title="Who We Work With"
                subtitle="Alliances and processes with communities, institutions, and projects that share our vision."
            />
            
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5 mt-10 sm:mt-14">
                <div class="bg-soil-raised p-5 sm:p-7 rounded-xl text-center" data-animate>
                    <div class="text-3xl sm:text-4xl mb-4">🏘️</div>
                    <h3 class="text-white font-semibold text-base sm:text-lg">Communities</h3>
                    <p class="text-stone-400 text-sm mt-2">Knowledge bearers</p>
                </div>
                <div class="bg-soil-raised p-5 sm:p-7 rounded-xl text-center" data-animate>
                    <div class="text-3xl sm:text-4xl mb-4">🎓</div>
                    <h3 class="text-white font-semibold text-base sm:text-lg">Education</h3>
                    <p class="text-stone-400 text-sm mt-2">Youth and processes</p>
                </div>
                <div class="bg-soil-raised p-5 sm:p-7 rounded-xl text-center" data-animate>
                    <div class="text-3xl sm:text-4xl mb-4">🏛️</div>
                    <h3 class="text-white font-semibold text-base sm:text-lg">Institutions</h3>
                    <p class="text-stone-400 text-sm mt-2">Cultural spaces</p>
                </div>
                <div class="bg-soil-raised p-5 sm:p-7 rounded-xl text-center" data-animate>
                    <div class="text-3xl sm:text-4xl mb-4">🤝</div>
                    <h3 class="text-white font-semibold text-base sm:text-lg">Cooperation</h3>
                    <p class="text-stone-400 text-sm mt-2">Sustainable projects</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-16 sm:py-20 md:py-24 bg-clay-600" data-animate>
        <div class="max-w-4xl mx-auto px-5 text-center">
            <h2 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-white mb-6">
                Want to activate living heritage in your territory?
            </h2>
            <p class="text-white/80 text-lg sm:text-xl mb-10 px-2 leading-relaxed">
                Contact us to explore co-creation possibilities.
            </p>
            <a href="/en/contacto/" class="inline-block bg-soil-void hover:bg-soil-deep text-white font-semibold uppercase text-sm sm:text-base tracking-wider px-10 py-4 rounded-full transition-all hover:scale-105">
                Write to Us
            </a>
        </div>
    </section>
</Layout>

<script>
    const animateOnScroll = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('[data-animate]').forEach((el) => {
        animateOnScroll.observe(el);
    });

    document.querySelectorAll('[data-animate-card]').forEach((el, index) => {
        (el as HTMLElement).style.transitionDelay = `${index * 100}ms`;
        animateOnScroll.observe(el);
    });

    document.querySelectorAll('.animate-method').forEach((el, index) => {
        (el as HTMLElement).style.transitionDelay = `${index * 150}ms`;
        animateOnScroll.observe(el);
    });
</script>

<style>
    [data-animate] {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    [data-animate].visible {
        opacity: 1;
        transform: translateY(0);
    }

    .animate-method {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.5s ease-out, transform 0.5s ease-out;
    }
    .animate-method.visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>
