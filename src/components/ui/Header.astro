---
import Logo from "@/assets/logo.svg";
import Nav from "./Nav.jsx";

interface Props {
    bgImage: string;
    subtitle: string;
}
const { subtitle, bgImage } = Astro.props;
---

<header class="h-72 md:h-80 relative">
    <div
        class="absolute inset-0 bg-center bg-cover"
        style={{ backgroundImage: `url(${bgImage})` }}
    >
    </div>
    <div class="absolute inset-0 bg-soil-void/70"></div>
    
    <!-- Nav Mobile: Hamburger arriba derecha -->
    <div class="md:hidden absolute top-4 right-4 z-50">
        <Nav client:load />
    </div>
    
    <!-- Logo centrado arriba -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 py-3 md:py-6">
        <div class="flex flex-col items-center md:flex-row md:justify-between md:items-start">
            <a href="/" class="shrink-0 mx-auto md:mx-0">
                <Logo class="w-36 sm:w-48 md:w-64" />
            </a>
            <!-- Nav Desktop -->
            <div class="hidden md:block">
                <Nav client:load />
            </div>
        </div>
    </div>

    <h1 class="absolute bottom-6 md:bottom-8 left-0 right-0 text-2xl md:text-4xl font-black uppercase text-white text-center px-4">
        {subtitle}
    </h1>
</header>
